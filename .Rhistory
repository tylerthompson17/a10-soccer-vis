library(tidyverse)
library(ggimage)
library(googlesheets4)
library(scales)
sheet_url <- "https://docs.google.com/spreadsheets/d/17ve6Orx7NRok2XsllC52on6BPVtvAI02jeuWrgZSC-M/edit?gid=0#gid=0"
sheet_range <- "Q2:T15"
df_raw <- read_sheet(
ss = sheet_url,
range = sheet_range,
col_types = "cdd?" # School=character, CPCT=double, Soccer Scholars=double, Dollars=guess
)
# ---- 4) Clean + keep only needed columns
# Your block has: School | CPCT. | Soccer Scholars | Soccer Sch. Dollars
df <- df_raw %>%
# keep just what we need
select(School, `CPCT.`, `Soccer Sch. Dollars`) %>%
rename(
school = School,
cpct = `CPCT.`,
scholarship = `Soccer Sch. Dollars`
) %>%
# drop empty rows just in case
filter(!is.na(school), school != "") %>%
# ensure scholarship is numeric even if it came in like "$1,215,030"
mutate(
scholarship = parse_number(as.character(scholarship))
)
library(tidyverse)
library(ggimage)
library(googlesheets4)
library(scales)
sheet_url <- "https://docs.google.com/spreadsheets/d/17ve6Orx7NRok2XsllC52on6BPVtvAI02jeuWrgZSC-M/edit?gid=0#gid=0"
sheet_range <- "Q2:T15"
df_raw <- read_sheet(
ss = sheet_url,
range = sheet_range,
col_types = "cdd?" # School=character, CPCT=double, Soccer Scholars=double, Dollars=guess
)
df <- df_raw %>%
# keep just what we need
select(School, `CPCT.`, `Men's Soccer Sch. Dollars`) %>%
rename(
school = School,
cpct = `CPCT.`,
scholarship = `Men's Soccer Sch. Dollars`
) %>%
# drop empty rows just in case
filter(!is.na(school), school != "") %>%
# ensure scholarship is numeric even if it came in like "$1,215,030"
mutate(
scholarship = parse_number(as.character(scholarship))
)
davidson_with_aid <- df %>%
filter(school == "Davidson") %>%
mutate(
school = "Davidson (With Aid)",
#####################################
scholarship = 666666  # <-- EDIT THIS
###### ^^^^ CHANGE IMPORTANT #######
######                       #######
)
df_plot <- bind_rows(df, davidson_with_aid)
slugify <- function(x) {
x %>%
str_to_lower() %>%
str_replace_all("\\(.*\\)", "") %>%   # remove parenthetical labels
str_replace_all("[^a-z0-9]", "") %>%  # remove spaces/punct
str_trim()
}
df_plot <- df_plot %>%
mutate(
logo = file.path("A10 Logos", paste0(slugify(school), ".png"))
)
df_plot <- df_plot %>%
mutate(
logo = if_else(str_detect(school, "^Davidson"), file.path("A10 Logos", "davidson.png"), logo)
)
missing <- df_plot %>% filter(!file.exists(logo)) %>% distinct(school, logo)
if (nrow(missing) > 0) {
print("Missing logo files for these rows (fix filenames or slug rules):")
print(missing)
}
p <- ggplot(df_plot, aes(x = scholarship, y = cpct)) +
geom_image(aes(image = logo), size = 0.07) +
# optional labels (comment out if you want a cleaner graphic)
geom_text(aes(label = school), nudge_y = 0.015, size = 3) +
scale_x_continuous(labels = dollar_format()) +
scale_y_continuous(limits = c(0, 1)) +
labs(
title = "A10 Men's Soccer: Winning/Points % vs Scholarship Spending",
x = "Scholarship Dollars Spent",
y = "Winning / Points % (CPCT)"
) +
theme_minimal(base_size = 14)
print(p)
print(p)
